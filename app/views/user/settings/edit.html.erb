<div class="space-y-6 max-w-2xl mx-auto">
  <div>
    <h1 class="text-xl font-bold" style="color: #E2E8F0;">Settings</h1>
    <p class="text-sm mt-0.5" style="color: #8892A4;">Manage your account and preferences</p>
  </div>

  <%# Profile section %>
  <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
    <div class="px-5 py-4 border-b" style="border-color: #2A2F45;">
      <h2 class="text-sm font-semibold" style="color: #E2E8F0;">Profile</h2>
    </div>

    <%= form_with model: @user, url: user_settings_path, method: :patch, class: "p-5 space-y-4" do |f| %>
      <%= hidden_field_tag :section, "profile" %>

      <% if @user.errors.any? && params[:section] != "password" %>
        <div class="px-4 py-3 rounded-lg text-sm border" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;">
          <% @user.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Name</label>
          <%= f.text_field :name,
              class: "w-full px-3 py-2.5 rounded-lg text-sm border outline-none transition-colors focus:border-purple-500",
              style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
              placeholder: "Your name" %>
        </div>

        <div>
          <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Email</label>
          <%= f.email_field :email,
              class: "w-full px-3 py-2.5 rounded-lg text-sm border outline-none transition-colors focus:border-purple-500",
              style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
              placeholder: "your@email.com" %>
        </div>

        <div>
          <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Currency</label>
          <%= f.select :currency,
              [["BRL — Brazilian Real", "BRL"], ["USD — US Dollar", "USD"], ["EUR — Euro", "EUR"]],
              { selected: @user.currency || "BRL" },
              class: "w-full px-3 py-2.5 rounded-lg text-sm border outline-none",
              style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;" %>
        </div>
      </div>

      <div class="flex justify-end pt-2">
        <%= f.submit "Save Changes",
            class: "px-5 py-2 rounded-lg text-sm font-semibold transition-colors hover:opacity-90 cursor-pointer",
            style: "background-color: #6C63FF; color: white;" %>
      </div>
    <% end %>
  </div>

  <%# Password section %>
  <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
    <div class="px-5 py-4 border-b" style="border-color: #2A2F45;">
      <h2 class="text-sm font-semibold" style="color: #E2E8F0;">Change Password</h2>
    </div>

    <%= form_with model: @user, url: user_settings_path, method: :patch, class: "p-5 space-y-4" do |f| %>
      <%= hidden_field_tag :section, "password" %>

      <% if @user.errors.any? && params[:section] == "password" %>
        <div class="px-4 py-3 rounded-lg text-sm border" style="background-color: rgba(255,107,107,0.1); border-color: #FF6B6B; color: #FF6B6B;">
          <% @user.errors.full_messages.each do |msg| %>
            <p><%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div class="space-y-4">
        <div>
          <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Current Password</label>
          <%= f.password_field :current_password,
              class: "w-full px-3 py-2.5 rounded-lg text-sm border outline-none transition-colors",
              style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
              autocomplete: "current-password" %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">New Password</label>
            <%= f.password_field :password,
                class: "w-full px-3 py-2.5 rounded-lg text-sm border outline-none transition-colors",
                style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
                autocomplete: "new-password",
                placeholder: "Min 6 characters" %>
          </div>

          <div>
            <label class="block text-xs font-medium mb-1.5" style="color: #8892A4;">Confirm New Password</label>
            <%= f.password_field :password_confirmation,
                class: "w-full px-3 py-2.5 rounded-lg text-sm border outline-none transition-colors",
                style: "background-color: #0F1117; border-color: #2A2F45; color: #E2E8F0;",
                autocomplete: "new-password" %>
          </div>
        </div>
      </div>

      <div class="flex justify-end pt-2">
        <%= f.submit "Update Password",
            class: "px-5 py-2 rounded-lg text-sm font-semibold transition-colors hover:opacity-90 cursor-pointer",
            style: "background-color: #6C63FF; color: white;" %>
      </div>
    <% end %>
  </div>

  <%# Danger zone %>
  <div class="rounded-xl border overflow-hidden" style="background-color: #1E2130; border-color: #2A2F45;">
    <div class="px-5 py-4 border-b" style="border-color: #2A2F45;">
      <h2 class="text-sm font-semibold" style="color: #FF6B6B;">Danger Zone</h2>
    </div>
    <div class="p-5 flex items-center justify-between">
      <div>
        <p class="text-sm font-medium" style="color: #E2E8F0;">Sign out of all devices</p>
        <p class="text-xs mt-0.5" style="color: #8892A4;">Ends all active sessions</p>
      </div>
      <%= link_to destroy_user_session_path, data: { turbo_method: :delete },
          class: "px-4 py-2 rounded-lg text-sm font-medium transition-colors hover:opacity-90",
          style: "border: 1px solid #FF6B6B; color: #FF6B6B;" do %>
        Sign Out
      <% end %>
    </div>
  </div>
</div>
